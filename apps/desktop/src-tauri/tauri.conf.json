{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image Prompt Lab",
  "version": "0.1.0",
  "identifier": "dev.honghao.image-prompt-lab",
  "build": {
    "beforeDevCommand": "cargo build -p imglab-daemon && npm run dev",
    "beforeBuildCommand": "cargo build -p imglab-daemon && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Image Prompt Lab",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGNTYyNDY1MjU3MkQwOTkKUldTWjBISWxaU1JXTDNJVUFRdTRkOGZLdlYyMEtnSFpIRXFOc1RrR0ZPeGIxaUduL0paYm9UZDUK",
      "endpoints": [
        "https://github.com/danshan/image-prompt-lab-gallery/releases/latest/download/latest.json"
      ]
    }
  }
}
